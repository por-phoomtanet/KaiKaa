# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง
# คำสั่ง: cp .env.example .env

# API
PORT=8080

# MongoDB (รันใน docker-compose ใช้ host = mongo)
MONGO_URI=mongodb://mongo:27017
MONGO_DB=kaikaa

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# AI (openrouter) — ขอ key ที่ https://openrouter.ai/keys
OPENROUTER_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
